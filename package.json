{
  "name": "knksongs",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm run build:ts && node scripts/build-site.mjs",
    "build:pages-artifact": "npm run build && node scripts/build-pages-artifact.mjs --site-dir _build",
    "build:songs-json": "node scripts/build-songs-json.mjs",
    "build:ts": "node scripts/build-ts.mjs",
    "check:ts-emit": "node scripts/build-ts.mjs --check",
    "validate:songs-json": "node scripts/validate-songs-json.mjs",
    "lint": "eslint .",
    "typecheck": "tsc --project tsconfig.json",
    "test:unit": "npm run build:ts && node --test tests/*.mjs",
    "test:e2e": "npm run build:ts && playwright test",
    "test:e2e:headed": "npm run build:ts && playwright test --headed",
    "test:e2e:debug": "npm run build:ts && playwright test --debug"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.53.0",
    "eslint": "^9.39.4",
    "globals": "^17.6.0",
    "typescript": "^6.0.3"
  }
}
