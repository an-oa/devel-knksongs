{
  "name": "knksongs",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node scripts/build-site.mjs",
    "build:pages-artifact": "npm run build && node scripts/build-pages-artifact.mjs --site-dir _build",
    "build:songs-json": "npm run build:ts && npm run build:songs-json:raw",
    "build:songs-json:raw": "node scripts/build-songs-json.mjs",
    "build:ts": "node scripts/build-ts.mjs",
    "check:ts-emit": "node scripts/build-ts.mjs --check",
    "check:ts-emit:raw": "node scripts/build-ts.mjs --check-only",
    "validate:songs-json": "npm run build:ts && npm run validate:songs-json:raw",
    "validate:songs-json:raw": "node scripts/validate-songs-json.mjs",
    "lint": "npm run build:ts && npm run lint:raw",
    "lint:raw": "eslint .",
    "typecheck": "npm run build:ts && npm run typecheck:raw",
    "typecheck:raw": "tsc --project tsconfig.json",
    "test:unit": "npm run build:ts && npm run test:unit:raw",
    "test:unit:raw": "node --test tests/*.mjs",
    "test:e2e": "npm run build && playwright test",
    "test:e2e:headed": "npm run build && playwright test --headed",
    "test:e2e:debug": "npm run build && playwright test --debug"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.53.0",
    "eslint": "^9.39.4",
    "globals": "^17.6.0",
    "typescript": "^6.0.3"
  }
}
